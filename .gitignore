# =========================================================
# Unreal Engine 5 Git Ignore
# =========================================================

# Visual Studio / Rider / VSCode
.vs/
.idea/
.vscode/
*.VC.db
*.VC.opendb
*.suo
*.sln
*.opensdf
*.sdf

# OS Files
.DS_Store
Thumbs.db

# =========================================================
# Unreal Generated Folders
# =========================================================

Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Plugin Generated Folders
Plugins/*/Binaries/
Plugins/*/Intermediate/

# =========================================================
# Build Files
# =========================================================

Build/*

# Keep Build Config Files
!Build/*/
!Build/*/PakBlacklist*.txt

# Keep Icons
!Build/**/*.ico

# =========================================================
# Compiled Source / Libraries
# =========================================================

*.obj
*.o
*.lo
*.slo
*.pdb
*.ilk
*.lib
*.a
*.so
*.dylib
*.dll
*.exe
*.app
*.ipa

# =========================================================
# Precompiled Headers
# =========================================================

*.gch
*.pch

# =========================================================
# Source Art (Optional)
# Uncomment if you do NOT want raw source art in repo
# =========================================================

# SourceArt/**/*.png
# SourceArt/**/*.tga
# SourceArt/**/*.psd
# SourceArt/**/*.kra

# =========================================================
# Unreal Auto Generated
# =========================================================

*_BuiltData.uasset

# =========================================================
# Logs / Crash Dumps
# =========================================================

*.log
*.dmp

# =========================================================
# Temporary Files
# =========================================================

*.tmp
*.temp

# =========================================================
# Ignore Autosaves / Backups
# =========================================================

Saved/Autosaves/
Saved/Backup/

# =========================================================
# Keep Important Project Files
# =========================================================

!*.uproject
!Config/
!Content/
!Source/

# =========================================================
# Optional Large Binary Formats
# Uncomment if needed
# =========================================================

# *.blend
# *.fbx
# *.psd
# *.kra